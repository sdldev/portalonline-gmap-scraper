{
  "PreToolUse": [
    {
      "matcher": "Create|Edit|ApplyPatch",
      "hooks": [
        {
          "type": "command",
          "command": "\"$DROID_PROJECT_DIR\"/.factory/hooks/protect-files.sh",
          "timeout": 3
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Create|Edit|ApplyPatch",
      "hooks": [
        {
          "type": "command",
          "command": "\"$DROID_PROJECT_DIR\"/.factory/hooks/format.sh",
          "timeout": 15
        },
        {
          "type": "command",
          "command": "\"$DROID_PROJECT_DIR\"/.factory/hooks/test-on-edit.sh",
          "timeout": 60
        },
        {
          "type": "command",
          "command": "\"$DROID_PROJECT_DIR\"/.factory/hooks/scan-secrets.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"$DROID_PROJECT_DIR\"/.factory/hooks/docs-coverage.py",
          "timeout": 10
        }
      ]
    }
  ]
}
