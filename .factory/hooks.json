{
  "PreToolUse": [
    {
      "matcher": "Create|Edit|ApplyPatch",
      "hooks": [
        {
          "type": "command",
          "command": "hooks/protect-files.sh"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Create|Edit|ApplyPatch",
      "hooks": [
        {
          "type": "command",
          "command": "hooks/format.sh"
        },
        {
          "type": "command",
          "command": "hooks/test-on-edit.sh"
        },
        {
          "type": "command",
          "command": "hooks/scan-secrets.sh"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "hooks/docs-coverage.py"
        }
      ]
    }
  ]
}
